# Environment Variables for Vini AI

# API Configuration
API_KEYS=demo-key-123,free-tier-user
DEFAULT_MODEL=tinyllama
PORT=3000

# Ollama
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_NUM_PARALLEL=1
OLLAMA_KEEP_ALIVE=30m

# Database (MongoDB Atlas)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/vini-ai?retryWrites=true&w=majority

# Node Environment
NODE_ENV=production

# Optional: For production
DOMAIN=your-domain.railway.app
